{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "Jordan Law MCP",
  "description": "Golden contract tests for the Jordan Law MCP",
  "tests": [
    {
      "id": "jo-search-001",
      "category": "search",
      "description": "Search for cybercrime provisions in Arabic",
      "tool": "search_legislation",
      "input": {
        "query": "الجرائم الإلكترونية"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["الإلكترونية"]
      }
    },
    {
      "id": "jo-search-002",
      "category": "search",
      "description": "Search for money laundering provisions",
      "tool": "search_legislation",
      "input": {
        "query": "غسل الأموال"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["الأموال"]
      }
    },
    {
      "id": "jo-search-003",
      "category": "search",
      "description": "Search for privacy provisions",
      "tool": "search_legislation",
      "input": {
        "query": "الحياة الخاصة"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["الخاصة"]
      }
    },
    {
      "id": "jo-provision-001",
      "category": "provision",
      "description": "Get Article 7 of the Constitution (personal freedom)",
      "tool": "get_provision",
      "input": {
        "document_id": "constitution",
        "article": "7"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["الحرية الشخصية"],
        "text_not_empty": true
      }
    },
    {
      "id": "jo-provision-002",
      "category": "provision",
      "description": "Get Article 3 of the Cybercrime Law (unauthorized access)",
      "tool": "get_provision",
      "input": {
        "document_id": "cybercrime-law-2023",
        "article": "3"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["الشبكة المعلوماتية"],
        "text_not_empty": true
      }
    },
    {
      "id": "jo-search-004",
      "category": "search",
      "description": "Search for electronic signature provisions",
      "tool": "search_legislation",
      "input": {
        "query": "التوقيع الإلكتروني"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["الإلكتروني"]
      }
    },
    {
      "id": "jo-search-005",
      "category": "search",
      "description": "Search for consumer protection provisions",
      "tool": "search_legislation",
      "input": {
        "query": "المستهلك"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["المستهلك"]
      }
    },
    {
      "id": "jo-edge-001",
      "category": "edge",
      "description": "Handle nonexistent search gracefully",
      "tool": "search_legislation",
      "input": {
        "query": "xyznonexistent123"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
